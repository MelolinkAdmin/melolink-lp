{
  "backend": {
    "name": "git-gateway",
    "branch": "main",
    "site_domain": "melolink-lp.netlify.app",
    "identity_url": "https://melolink.netlify.app/.netlify/identity",
    "gateway_url": "https://melolink.netlify.app/.netlify/git/gateway"
  },
  "media_folder": "public/images",
  "public_folder": "/images",
  "collections": [
    {
      "name": "configuracoes",
      "label": "Configurações",
      "files": [
        {
          "label": "Planos de Internet",
          "name": "planos",
          "file": "public/data/planos.json",
          "fields": [
            {
              "label": "Lista de Planos",
              "name": "plans",
              "widget": "list",
              "fields": [
                { "label": "ID (slug)", "name": "id", "widget": "string" },
                { "label": "Título", "name": "title", "widget": "string" },
                { "label": "Velocidade", "name": "speed", "widget": "string" },
                { "label": "Unidade (Mega/Giga)", "name": "unit", "widget": "string" },
                { "label": "Preço", "name": "price", "widget": "string" },
                { "label": "Ícone", "name": "iconClass", "widget": "select", "options": ["wifi", "home", "game", "rocket", "zap", "tv", "globe"] },
                { "label": "Tema", "name": "theme", "widget": "select", "options": ["light", "dark"] },
                { "label": "Cor", "name": "color", "widget": "select", "options": ["indigo", "red", "purple"] },
                { "label": "Mais Vendido?", "name": "isBestSeller", "widget": "boolean", "default": false },
                { "label": "Benefícios", "name": "benefits", "widget": "list" }
              ]
            }
          ]
        }
      ]
    }
  ]
}